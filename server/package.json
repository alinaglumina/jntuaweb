{
  "name": "jntuaweb-server",
  "version": "2.0.0",
  "description": "JNTUA Web Portal — Express + MongoDB API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
